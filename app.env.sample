# FreeIPA environment configuration
# Copy to app.env and customize before starting

# Timezone
TZ=America/New_York

# Hostname and domain (IPA realm is derived from BASE_DOMAIN_NAME, uppercased)
BASE_HOST_NAME=freeipa
BASE_DOMAIN_NAME=example.com

# IPA admin password (used during first-run setup)
APP_ADMIN_PASS=changeme_admin_password
